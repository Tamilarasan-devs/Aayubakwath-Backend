generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String        @id @default(uuid())
  name            String
  email           String?       @unique
  phoneNumber     String?       @unique
  password        String
  role            Role          @default(USER)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  isEmailVerified Boolean       @default(false)
  otpCode         String?
  otpExpiry       DateTime?
  addresses       Address[]
  cartItems       CartItem[]
  couponUsage     CouponUsage[]
  orders          Order[]
  reviews         Review[]
  wishlist        Wishlist[]

  @@index([email])
  @@index([phoneNumber])
  @@map("users")
}

model Category {
  id        String           @id @default(uuid())
  name      String           @default("")
  image     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  banners   CategoryBanner[]
  products  Product[]

  @@map("categories")
}

model Product {
  id                 String          @id @default(uuid())
  productName        String
  productDescription String?
  productTags        Json            @default("[]")
  offerTags          Json?
  forWhom            String          @default("Not specified")
  withWhom           String          @default("Not specified")
  price              Decimal         @db.Decimal(10, 2)
  finalPrice         Decimal?        @default(0) @db.Decimal(10, 2)
  priceTiers         Json            @default("[]")
  productImages      Json?
  grabCode           String?
  grabPrice          Decimal?        @db.Decimal(10, 2)
  isActive           Boolean         @default(true)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  categoryId         String
  cartItems          CartItem[]
  orderItems         OrderItem[]
  content            ProductContent?
  category           Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  reviews            Review[]
  wishlistItems      Wishlist[]

  @@index([categoryId])
  @@index([productName])
  @@map("products")
}

model ProductContent {
  id        String   @id @default(uuid())
  content   Json
  productId String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_contents")
}

model CartItem {
  id        String   @id @default(uuid())
  quantity  Int      @default(1)
  userId    String
  productId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@map("cart_items")
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@map("wishlist")
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  productId String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([userId])
  @@map("reviews")
}

model Order {
  id              String        @id @default(uuid())
  userId          String
  totalAmount     Decimal       @db.Decimal(10, 2)
  status          OrderStatus   @default(PROCESSING)
  shippingAddress Json
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  couponCode      String?
  couponId        String?
  discountAmount  Decimal       @default(0) @db.Decimal(10, 2)
  subtotalAmount  Decimal?      @db.Decimal(10, 2)
  couponUsages    CouponUsage[]
  items           OrderItem[]
  coupon          Coupon?       @relation(fields: [couponId], references: [id])
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([couponId])
  @@map("orders")
}

model OrderItem {
  id              String   @id @default(uuid())
  orderId         String
  productId       String
  quantity        Int      @default(1)
  priceAtPurchase Decimal  @db.Decimal(10, 2)
  createdAt       DateTime @default(now())
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Address {
  id          String   @id @default(uuid())
  userId      String
  street      String
  city        String
  state       String
  postalCode  String
  country     String   @default("India")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  addressType String   @default("Home")
  area        String?
  doorNumber  String?
  landmark    String?
  name        String?
  phone       String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("addresses")
}

model Announcement {
  id        String   @id @default(uuid())
  title     String
  content   String   @default("")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("announcements")
}

model HomeBanner {
  id        String   @id @default(uuid())
  image     String
  link      String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("home_banners")
}

model OfferBanner {
  id        String   @id @default(uuid())
  image     String
  link      String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("offer_banners")
}

model CategoryBanner {
  id         String   @id @default(uuid())
  image      String
  link       String?
  order      Int      @default(0)
  isActive   Boolean  @default(true)
  categoryId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@map("category_banners")
}

model OfferBar {
  id        String   @id @default(uuid())
  text      String
  link      String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("offer_bars")
}

model ContactInquiry {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  message   String
  source    String   @default("website")
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
  @@map("contact_inquiries")
}

model BulkOrder {
  id              String   @id @default(uuid())
  name            String
  email           String
  mobile          String
  state           String
  productQuantity String
  totalQuantity   String
  details         String?
  source          String   @default("website")
  createdAt       DateTime @default(now())

  @@index([email])
  @@index([mobile])
  @@index([createdAt])
  @@map("bulk_orders")
}

model Coupon {
  id                    String        @id @default(uuid())
  code                  String        @unique
  description           String?
  discountType          String
  discountValue         Decimal       @db.Decimal(10, 2)
  minOrderAmount        Decimal?      @db.Decimal(10, 2)
  maxDiscountAmount     Decimal?      @db.Decimal(10, 2)
  usageLimit            Int?
  perUserLimit          Int?
  startsAt              DateTime?
  expiresAt             DateTime?
  isActive              Boolean       @default(true)
  applicableProductIds  Json?
  applicableCategoryIds Json?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  usages                CouponUsage[]
  orders                Order[]

  @@index([isActive])
  @@index([expiresAt])
  @@map("coupons")
}

model CouponUsage {
  id             String   @id @default(uuid())
  userId         String
  couponId       String
  orderId        String?
  discountAmount Decimal  @db.Decimal(10, 2)
  usedAt         DateTime @default(now())
  coupon         Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  order          Order?   @relation(fields: [orderId], references: [id])
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([couponId])
  @@index([orderId])
  @@map("coupon_usages")
}

enum Role {
  USER
  ADMIN
  MODERATOR
}

enum OrderStatus {
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}
