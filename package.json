{
  "name": "backend",
  "version": "3.0.0",
  "description": "Production-grade TypeScript Express backend with Prisma",
  "main": "dist/src/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/src/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-analytics": "tsx prisma/seed-analytics.ts",
    "db:cleanup-analytics": "tsx prisma/cleanup-analytics.ts",
    "db:fix-admin-password": "tsx prisma/fix-admin-password.ts",
    "db:reset": "prisma migrate reset --force",
    "db:migrate-from-legacy": "tsx prisma/migrate-from-legacy.ts",
    "db:migrate-db-to-db": "tsx prisma/migrate-db-to-db.ts",
    "migrate:images": "tsx scripts/migrate-s3-to-cloudinary.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "axios": "^1.15.2",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.5.1",
    "compression": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "resend": "^6.12.2",
    "sequelize": "^6.37.8",
    "sharp": "^0.34.5",
    "uuid": "^13.0.0",
    "winston": "^3.17.0",
    "zod": "^3.25.76",
    "zod-validation-error": "^3.4.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/hpp": "^0.2.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.3.0",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "eslint": "^9.32.0",
    "prettier": "^3.6.2",
    "prisma": "^6.5.0",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "license": "ISC"
}
